// --- Telegram ---
// 1) No Telegram, fale com o @BotFather, mande /newbot e siga os passos.
//    Ele te da um TOKEN parecido com "123456789:AAExxxxxxxxxxxxxxxxxxxxx".
#define TELEGRAM_BOT_TOKEN        "123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxx"

// 2) Quem pode comandar o alimentador (seu chat_id numerico).
//    Deixe em 0 no inicio: ao mandar qualquer mensagem o bot te responde
//    com o seu chat_id. Depois cole o numero aqui e regrave o firmware
//    para que SO voce consiga acionar o alimentador.
#define TELEGRAM_ALLOWED_CHAT_ID  0
